# ── Staff data ─────────────────────────────────────────────
# data/ holds the per-unit Markdown files — personal data (names,
# staff IDs, Scholar IDs). Never commit it. Copy data.example/ to
# data/ to get started.
data/

# Legacy single-file format (pre-Markdown) and its backups
staff.json
staff.bak.*.json

# Cached Google Scholar payloads (per-profile, 7-day TTL)
.cache/

# REF 2029 per-publication flags + per-UoA targets (user state).
# Generated at runtime; lives in ~/Library/Application Support/Scholar
# Dashboard/ when running from the packaged .app.
ref_flags.json
ref_targets.json
settings.json
case_studies.json

# Exports
scholar-dashboard-*.json
scholar-export-*.json

# .app launcher log
.scholar-dashboard.log

# ── Python ─────────────────────────────────────────────────
.venv/
.venv-build/
__pycache__/
*.pyc

# ── PyInstaller build artefacts ────────────────────────────
build/
dist/

# ── OS / editor ────────────────────────────────────────────
.DS_Store
